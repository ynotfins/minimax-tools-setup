# pgVector Configuration Template
# Copy to your PostgreSQL data directory as postgresql.conf

# Vector Extension
shared_preload_libraries = 'vector'

# Memory Settings
shared_buffers = 256MB
effective_cache_size = 1GB
maintenance_work_mem = 128MB
work_mem = 64MB

# Vector Search Optimization
max_parallel_workers_per_gather = 2
effective_parallel_workers = 2

# Connection Settings
max_connections = 100

# Write-Ahead Log
wal_level = replica
max_wal_size = 1GB
min_wal_size = 80MB
