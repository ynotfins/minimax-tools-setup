# MiniMax Agent Tools - Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to git!

# PostgreSQL / pgVector Connection (external drives)
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_DB=vector_db
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=  # Set your password here
PGVECTOR_SSL_MODE=prefer

# Database Paths (if using external drives)
# PGVECTOR_DATA_DIR=E:\postgres_data  # Database files
# PGVECTOR_EXT_DIR=F:\pgvector_ext    # Vector extensions

# OpenAI API (for embeddings)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic API (for Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=https://api.anthropic.com

# Application Settings
LOG_LEVEL=INFO
READ_ONLY_MODE=true  # Set to false only when intentionally writing
